   "cell_type": "raw",
   "source": [
    "{\n",
    "  \"cells\": [\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"# 02 Labeling Logic\\n\",\n",
    "        \"\\n\",\n",
    "        \"`data_R2.csv` 또는 `data/interim/data_with_header.csv`를 불러와 rule-based 상태 라벨을 생성하는 예시 노트북입니다.\\n\",\n",
    "        \"\\n\",\n",
    "        \"이 노트북에서는:\\n\",\n",
    "        \"- 데이터 로딩\\n\",\n",
    "        \"- 컬럼 확인\\n\",\n",
    "        \"- build_state_label 실행\\n\",\n",
    "        \"- 레이블 분포 확인\\n\",\n",
    "        \"- 시간대별 레이블 빈도 시각화\\n\",\n",
    "        \"- 이상 상태 샘플 출력을 보여줍니다.\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 1. 라이브러리 및 데이터 로딩\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"import pandas as pd\\n\",\n",
    "        \"import numpy as np\\n\",\n",
    "        \"import matplotlib.pyplot as plt\\n\",\n",
    "        \"import seaborn as sns\\n\",\n",
    "        \"from pathlib import Path\\n\",\n",
    "        \"import warnings\\n\",\n",
    "        \"warnings.filterwarnings('ignore')\\n\",\n",
    "        \"\\n\",\n",
    "        \"from src.labeling.labeling import DEFAULT_CONFIG, build_state_label, summarize_label_distribution, infer_available_columns\\n\",\n",
    "        \"\\n\",\n",
    "        \"plt.rcParams['figure.figsize'] = (12, 6)\\n\",\n",
    "        \"sns.set_style('whitegrid')\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(\\\"라이브러리 로드 완료\\\")\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 2. 데이터 로딩\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"data_paths = [\\n\",\n",
    "        \"    Path('../data/interim/data_with_header.csv'),\\n\",\n",
    "        \"    Path('../data/raw/data_R2.csv'),\\n\",\n",
    "        \"]\\n\",\n",
    "        \"\\n\",\n",
    "        \"df = None\\n\",\n",
    "        \"used_path = None\\n\",\n",
    "        \"header_status = None\\n\",\n",
    "        \"\\n\",\n",
    "        \"for path in data_paths:\\n\",\n",
    "        \"    if path.exists():\\n\",\n",
    "        \"        if 'header' in str(path):\\n\",\n",
    "        \"            df = pd.read_csv(path, header=0, na_values=['\\\\\\\\N', '\\\\\\\\N.1'])\\n\",\n",
    "        \"            header_status = \\\"헤더 포함\\\"\\n\",\n",
    "        \"        else:\\n\",\n",
    "        \"            df = pd.read_csv(path, header=None, na_values=['\\\\\\\\N', '\\\\\\\\N.1'])\\n\",\n",
    "        \"            header_status = \\\"헤더 없음\\\"\\n\",\n",
    "        \"        used_path = path\\n\",\n",
    "        \"        break\\n\",\n",
    "        \"\\n\",\n",
    "        \"if df is None:\\n\",\n",
    "        \"    print(\\\"에러: 데이터 파일을 찾지 못했습니다\\\")\\n\",\n",
    "        \"else:\\n\",\n",
    "        \"    print(f\\\"✓ 데이터 로드 완료\\\")\\n\",\n",
    "        \"    print(f\\\"  파일: {used_path}\\\")\\n\",\n",
    "        \"    print(f\\\"  상태: {header_status}\\\")\\n\",\n",
    "        \"    print(f\\\"  크기: {df.shape[0]:,} rows × {df.shape[1]} columns\\\")\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 3. 컬럼 확인 및 자동 추론\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"print(\\\"\\\\n=== 원본 컬럼 정보 ===\\\")\\n\",\n",
    "        \"print(f\\\"크기: {df.shape}\\\")\\n\",\n",
    "        \"print(f\\\"콜럼: {list(df.columns[:10])}...\\\")\\n\",\n",
    "        \"print(f\\\"\\\\n샘플 데이터:\\\")\\n\",\n",
    "        \"display(df.head(3))\\n\",\n",
    "        \"\\n\",\n",
    "        \"available_cols = infer_available_columns(df)\\n\",\n",
    "        \"print(f\\\"\\\\n=== 핵심 컬럼 자동 추론 ===\\\")\\n\",\n",
    "        \"essential_fields = ['timestamp', 'device_id', 'power', 'current', 'alarm_flag', 'eqp_status']\\n\",\n",
    "        \"for field in essential_fields:\\n\",\n",
    "        \"    col = available_cols.get(field)\\n\",\n",
    "        \"    status = \\\"✓\\\" if col is not None else \\\"✗\\\"\\n\",\n",
    "        \"    print(f\\\"{status} {field:15s} -> {col}\\\")\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 4. Rule-based 라벨링 실행\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"print(\\\"라벨링 진행 중...\\\")\\n\",\n",
    "        \"labeled_df = build_state_label(df, DEFAULT_CONFIG)\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(f\\\"✓ 라벨링 완료\\\")\\n\",\n",
    "        \"print(f\\\"  state_label 컬럼 추가됨\\\")\\n\",\n",
    "        \"print(f\\\"  데이터 크기: {labeled_df.shape}\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(f\\\"\\\\n=== 샘플 결과 (첫 5행) ===\\\")\\n\",\n",
    "        \"sample_cols = [col for col in labeled_df.columns \\n\",\n",
    "        \"               if col in ['timestamp', 'device_id', 'power_kw', 'current_a', 'temp_c', 'alarm_flag', 'state_label']]\\n\",\n",
    "        \"if sample_cols:\\n\",\n",
    "        \"    display(labeled_df[sample_cols].head())\\nelse:\\n\",\n",
    "        \"    display(labeled_df[['state_label']].head())\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 5. 레이블 분포 확인\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"print(\\\"=== 상태 레이블 분포 ===\\\")\\n\",\n",
    "        \"summary = summarize_label_distribution(labeled_df, label_col='state_label')\\n\",\n",
    "        \"display(summary)\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(\\\"\\\\n=== 시각화: 레이블 분포 ===\\\")\\n\",\n",
    "        \"fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\\n\",\n",
    "        \"\\n\",\n",
    "        \"summary_sorted = summary.sort_values('count', ascending=False)\\n\",\n",
    "        \"ax1.bar(summary_sorted['state_label'], summary_sorted['count'], color='steelblue')\\n\",\n",
    "        \"ax1.set_title('상태 레이블 빈도수', fontsize=12, fontweight='bold')\\n\",\n",
    "        \"ax1.set_ylabel('빈도')\\n\",\n",
    "        \"ax1.tick_params(axis='x', rotation=45)\\n\",\n",
    "        \"\\n\",\n",
    "        \"colors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd']\\n\",\n",
    "        \"ax2.pie(summary_sorted['count'], labels=summary_sorted['state_label'], autopct='%1.1f%%', \\n\",\n",
    "        \"        colors=colors[:len(summary_sorted)])\\n\",\n",
    "        \"ax2.set_title('상태 레이블 비율', fontsize=12, fontweight='bold')\\n\",\n",
    "        \"\\n\",\n",
    "        \"plt.tight_layout()\\n\",\n",
    "        \"plt.show()\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 6. 시간대별 레이블 빈도 시각화\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"ts_col = None\\n\",\n",
    "        \"for col in labeled_df.columns:\\n\",\n",
    "        \"    if 'timestamp' in str(col).lower() or 'time' in str(col).lower():\\n\",\n",
    "        \"        ts_col = col\\n\",\n",
    "        \"        break\\n\",\n",
    "        \"\\n\",\n",
    "        \"if ts_col:\\n\",\n",
    "        \"    print(f\\\"timestamp 컬럼: {ts_col}\\\")\\n\",\n",
    "        \"    labeled_df['parsed_time'] = pd.to_datetime(labeled_df[ts_col], errors='coerce')\\n\",\n",
    "        \"    labeled_df['hour'] = labeled_df['parsed_time'].dt.hour\\n\",\n",
    "        \"    \\n\",\n",
    "        \"    hourly_labels = labeled_df.groupby(['hour', 'state_label']).size().unstack(fill_value=0)\\n\",\n",
    "        \"    \\n\",\n",
    "        \"    print(f\\\"\\\\n=== 시간대별 레이블 빈도 (샘플) ===\\\")\\n\",\n",
    "        \"    display(hourly_labels.head(10))\\n\",\n",
    "        \"    \\n\",\n",
    "        \"    fig, ax = plt.subplots(figsize=(14, 6))\\n\",\n",
    "        \"    hourly_labels.plot(kind='bar', stacked=True, ax=ax, width=0.8)\\n\",\n",
    "        \"    ax.set_title('시간대별 상태 레이블 빈도', fontsize=12, fontweight='bold')\\n\",\n",
    "        \"    ax.set_xlabel('시간 (hour)')\\n\",\n",
    "        \"    ax.set_ylabel('빈도')\\n\",\n",
    "        \"    ax.legend(title='상태 레이블', bbox_to_anchor=(1.05, 1), loc='upper left')\\n\",\n",
    "        \"    plt.xticks(rotation=0)\\n\",\n",
    "        \"    plt.tight_layout()\\n\",\n",
    "        \"    plt.show()\\nelse:\\n\",\n",
    "        \"    print(\\\"⚠ timestamp 컬럼을 찾을 수 없습니다\\\")\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 7. 이상 상태 샘플 출력 (최대 10건)\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"print(\\\"=== 이상 상태 샘플 ===\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"alert_samples = labeled_df[labeled_df['state_label'] == 'alert_state'].head(5)\\n\",\n",
    "        \"if len(alert_samples) > 0:\\n\",\n",
    "        \"    print(f\\\"\\\\n**alert_state ({len(alert_samples)} 건)**\\\")\\n\",\n",
    "        \"    sample_cols = [col for col in alert_samples.columns \\n\",\n",
    "        \"                   if col in ['timestamp', 'device_id', 'power_kw', 'current_a', 'temp_c', 'alarm_flag', 'state_label']]\\n\",\n",
    "        \"    if not sample_cols:\\n\",\n",
    "        \"        sample_cols = list(alert_samples.columns[:7])\\n\",\n",
    "        \"    display(alert_samples[sample_cols])\\nelse:\\n\",\n",
    "        \"    print(\\\"\\\\nalert_state 샘플 없음\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"abnormal_samples = labeled_df[labeled_df['state_label'] == 'abnormal_pattern'].head(5)\\n\",\n",
    "        \"if len(abnormal_samples) > 0:\\n\",\n",
    "        \"    print(f\\\"\\\\n**abnormal_pattern ({len(abnormal_samples)} 건)**\\\")\\n\",\n",
    "        \"    sample_cols = [col for col in abnormal_samples.columns \\n\",\n",
    "        \"                   if col in ['timestamp', 'device_id', 'power_kw', 'current_a', 'temp_c', 'alarm_flag', 'state_label']]\\n\",\n",
    "        \"    if not sample_cols:\\n\",\n",
    "        \"        sample_cols = list(abnormal_samples.columns[:7])\\n\",\n",
    "        \"    display(abnormal_samples[sample_cols])\\nelse:\\n\",\n",
    "        \"    print(\\\"\\\\nabnormal_pattern 샘플 없음\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"fault_samples = labeled_df[labeled_df['state_label'] == 'suspected_sensor_fault'].head(5)\\n\",\n",
    "        \"if len(fault_samples) > 0:\\n\",\n",
    "        \"    print(f\\\"\\\\n**suspected_sensor_fault ({len(fault_samples)} 건)**\\\")\\n\",\n",
    "        \"    sample_cols = [col for col in fault_samples.columns \\n\",\n",
    "        \"                   if col in ['timestamp', 'device_id', 'power_kw', 'current_a', 'temp_c', 'alarm_flag', 'state_label']]\\n\",\n",
    "        \"    if not sample_cols:\\n\",\n",
    "        \"        sample_cols = list(fault_samples.columns[:7])\\n\",\n",
    "        \"    display(fault_samples[sample_cols])\\nelse:\\n\",\n",
    "        \"    print(\\\"\\\\nsuspected_sensor_fault 샘플 없음\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"total_anomalies = len(alert_samples) + len(abnormal_samples) + len(fault_samples)\\n\",\n",
    "        \"print(f\\\"\\\\n총 이상 상태 {total_anomalies} 건 출력 완료\\\")\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 8. 포트폴리오 설명 포인트\\n\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"execution_count\": null,\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"source\": [\n",
    "        \"print(\\\"\\\"\\\"\\n=== 포트폴리오 설명 포인트 ===\\n\\n1. **Rule-based Labeling의 의미**\\n   - alert_state: 명확한 안전 위협 신호 (알람, 고온 등) → 즉시 조치 필요\\n   - abnormal_pattern: 통계적 이상 (과부하, 급변) → 사전 점검 권장\\n   - suspected_sensor_fault: 센서 결함 의심 → 데이터 품질 관리\\n   - idle: 정상 유휴 상태 → 모니터링 범위 외\\n   - normal_operation: 정상 가동 범위 → 기준선\\n\\n2. **공유공장 도메인 특성**\\n   - 다중 테넌트 운영 → 시간대별 패턴 차이 관찰\\n   - 다양한 설비 타입 → device_id별 라벨 분포 다름\\n   - 24시간 가동 → 야간 비정상 탐지 중요\\n\\n3. **다음 단계**\\n   - 라벨 종합으로 threshold 조정\\n   - 오탐(false positive)과 미탐(false negative) 분석\\n   - 실제 라벨 vs weak label 비교\\n   - 지도학습(supervised learning)으로 확장\\n   - 멀티모달(CCTV, 환경센서) 결합 설계\\n\\\"\\\"\\\")\\n\"\n",
    "      ]\n",
    "    }\n",
    "  ],\n",
    "  \"metadata\": {\n",
    "    \"kernelspec\": {\n",
    "      \"display_name\": \"Python 3\",\n",
    "      \"language\": \"python\",\n",
