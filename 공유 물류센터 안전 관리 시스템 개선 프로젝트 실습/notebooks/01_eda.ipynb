   "source": [
    "{ \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# 01_EDA - data_R2.csv\\n\",\n",
    "    \"\\n\",\n",
    "    \"간단한 목적:\\n\",\n",
    "    \"- 컬럼 매핑 확인 및 header 확정\\n\",\n",
    "    \"- 결측/0값 패턴 확인(장비별)\\n\",\n",
    "    \"- 시간대별(시·일) 패턴: 가동/유휴, 야간 활동\\n\",\n",
    "    \"- 기본 상관관계(전력/전류/역률)\\n\",\n",
    "    \"- 알람/이상 샘플을 몇 개 뽑아 시각화\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Imports\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"DATA_RAW = Path('data/data_R2.csv')\\n\",\n",
    "    \"DATA_MAPPED = Path('data/interim/data_with_header.csv')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# If interim mapped file exists, prefer it; otherwise load raw (no header)\\n\",\n",
    "    \"if DATA_MAPPED.exists():\\n\",\n",
    "    \"    df = pd.read_csv(DATA_MAPPED)\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    df = pd.read_csv(DATA_RAW, header=None, na_values=['\\\\N','\\\\N.1'])\\n\",\n",
    "    \"\\n\",\n",
    "    \"df.shape\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 1) Quick head + dtypes + missing\\n\",\n",
    "    \"display(df.head())\\n\",\n",
    "    \"display(df.dtypes.to_frame('dtype'))\\n\",\n",
    "    \"display(df.isna().sum().to_frame('n_missing'))\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Device-level distributions\\n\",\n",
    "    \"- device_id별 row 수, 결측 패턴, 전력 평균 등 확인\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"if 'device_id' in df.columns:\\n\",\n",
    "    \"    display(df['device_id'].value_counts().to_frame('count'))\\n\",\n",
    "    \"    # per-device summary for key numeric cols (auto-detect)\\n\",\n",
    "    \"    numeric = df.select_dtypes(include=[\\'number\\']).columns.tolist()[:8]\\n\",\n",
    "    \"    display(df.groupby('device_id')[numeric].agg(['mean','std','median','count']).head())\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print('device_id 컬럼 없음 - 먼저 header 매핑을 수행하세요')\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Time parsing and time-of-day patterns\\n\",\n",
    "    \"- timestamp 컬럼을 datetime으로 변환 후 hour/day별 집계\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"if 'timestamp' in df.columns:\\n\",\n",
    "    \"    df['timestamp_parsed'] = pd.to_datetime(df['timestamp'], errors='coerce')\\n\",\n",
    "    \"    df['hour'] = df['timestamp_parsed'].dt.hour\\n\",\n",
    "    \"    display(df['hour'].value_counts().sort_index())\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print('timestamp 컬럼 없음 - header 매핑 또는 컬럼명 확인 필요')\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Correlation and pairwise scatter (basic)\\n\",\n",
    "    \"- 전력/전류/역률 등 주요 컬럼의 상관관계 확인\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"num_cols = df.select_dtypes(include=[\\'number\\']).columns.tolist()\\n\",\n",
    "    \"if len(num_cols) >= 3:\\n\",\n",
    "    \"    sub = df[num_cols].iloc[:10000].corr()\\n\",\n",
    "    \"    plt.figure(figsize=(8,6))\\n\",\n",
    "    \"    sns.heatmap(sub, annot=True, fmt='.2f', cmap='vlag')\\n\",\n",
    "    \"    plt.title('numeric correlation (sample)')\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print('numeric columns 부족')\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Alarm / anomaly sample visualization\\n\",\n",
    "    \"- alarm_flag 또는 이상치로 의심되는 샘플 몇 건을 추출해 시각화\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# placeholder: alarm flag가 있는 컬럼이 있다면 샘플 추출\\n\",\n",
    "    \"alarm_candidates = [c for c in df.columns if 'alarm' in str(c).lower()]\\n\",\n",
    "    \"if alarm_candidates:\\n\",\n",
    "    \"    af = alarm_candidates[0]\\n\",\n",
    "    \"    display(df[df[af].notna()].head())\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print('alarm 관련 컬럼 없음 - header 매핑 뒤 재확인')\\n\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
    " \"metadata\": {\"kernelspec\": {\"display_name\": \"Python 3\", \"language\": \"python\", \"name\": \"python3\"}, \"language_info\": {\"name\": \"python\"}},\n",
    " \"nbformat\": 4,\n",
    " \"nbformat_minor\": 2}\n"
